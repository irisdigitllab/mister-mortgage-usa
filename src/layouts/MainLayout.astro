---
import Base from './Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/nav';

export interface Props {
  title: string;
  description: string;
  lang?: Lang;
  canonical?: string;
  altLang?: string;
  ogImage?: string;
  hasTicker?: boolean;
  hasMap?: boolean;
}

const {
  title,
  description,
  lang = 'en',
  canonical,
  altLang,
  ogImage,
  hasTicker = true,
  hasMap = false,
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<Base {title} {description} {lang} {canonical} {altLang} {ogImage} {hasTicker}>

  <!-- Ticker bar -->
  {hasTicker && (
    <div class="contact-ticker" id="contact-ticker">
      <div class="ticker-track" id="ticker-track">
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.65A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <a href="tel:+13056151515">(305) 615-1515</a>
        </span>
        <span class="ticker-sep">|</span>
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <a href="https://maps.google.com/?q=6030+Bird+Rd,+Miami,+FL+33155" target="_blank" rel="noopener">6030 Bird Rd, Miami, FL 33155</a>
        </span>
        <span class="ticker-sep">|</span>
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:info@mistermortgageusa.com">info@mistermortgageusa.com</a>
        </span>
        <span class="ticker-sep">|</span>
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          NMLS #2572035
        </span>
        <span class="ticker-sep">|</span>
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Mon–Fri: 9AM–6PM &nbsp;|&nbsp; Sat–Sun: By appointment
        </span>
        <span class="ticker-sep">|</span>
        <span class="ticker-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          <a href="https://wa.me/13052141515?text=Hi!%20I%20found%20you%20online%20and%20I%27d%20like%20to%20learn%20more%20about%20your%20mortgage%20services." target="_blank" rel="noopener">WhatsApp Us</a>
        </span>
      </div>
    </div>
  )}

  <!-- WhatsApp chat widget -->
  <div class="wa-chat-widget" id="wa-chat-widget">
    <div class="wa-chat-popup" id="wa-chat-popup">
      <div class="wa-chat-header">
        <div class="wa-chat-avatar">
          <img src="https://mistermortgageusa.com/wp-content/uploads/2025/05/PNG-02.webp" alt="Mister Mortgage USA" />
        </div>
        <div class="wa-chat-info">
          <span class="wa-chat-name">Mister Mortgage USA</span>
          <span class="wa-chat-status">Typically replies within minutes</span>
        </div>
        <button class="wa-chat-close" id="wa-chat-close" aria-label="Close chat">&#215;</button>
      </div>
      <div class="wa-chat-body">
        <div class="wa-chat-bubble">
          <p>Hi! 👋 How can we help you today? Send us a message and we'll get back to you quickly!</p>
          <span class="wa-chat-bubble-time">Mister Mortgage USA</span>
        </div>
      </div>
      <div class="wa-chat-footer">
        <textarea class="wa-chat-input" id="wa-chat-input" rows="2" placeholder="Type a message..."></textarea>
        <button class="wa-chat-send" id="wa-chat-send" aria-label="Send message">
          <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>
    <button class="whatsapp-btn" id="wa-chat-btn" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </button>
  </div>

  <!-- Pre-qual modal -->
  <div class="modal-overlay" id="prequal-modal">
    <div class="modal-box" id="modal-box">
      <button class="modal-close" onclick="closePrequalModal()" aria-label="Close">&#215;</button>
      <div class="modal-progress-bar"><div class="modal-progress-fill" id="modal-progress"></div></div>
      <div id="modal-content"></div>
    </div>
  </div>

  <!-- Loan info modal -->
  <div class="modal-overlay" id="loan-info-modal">
    <div class="modal-box loan-info-box" id="loan-info-box">
      <button class="modal-close" onclick="closeLoanModal()" aria-label="Close">&#215;</button>
      <div id="loan-modal-content"></div>
    </div>
  </div>

  <Navbar {lang} currentPath={currentPath} />

  <main>
    <slot />
  </main>

  <Footer {lang} />

  {hasMap && (
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH" crossorigin="anonymous"></script>
  )}

</Base>
