  <script is:inline>
(function() {
  var neighborhoods = [
    { name: 'Brickell',      lat: 25.7617, lng: -80.1918, type: 'Condos & Investment' },
    { name: 'Coral Gables',  lat: 25.7215, lng: -80.2684, type: 'Premium Residential' },
    { name: 'Doral',         lat: 25.8195, lng: -80.3418, type: 'First-Time Buyers' },
    { name: 'Hialeah',       lat: 25.8576, lng: -80.2781, type: 'FHA Programs' },
    { name: 'Kendall',       lat: 25.6795, lng: -80.3569, type: 'Suburban Families' },
    { name: 'Coconut Grove', lat: 25.7269, lng: -80.2397, type: 'Luxury Properties' },
    { name: 'Aventura',      lat: 25.9565, lng: -80.1393, type: 'Condos & Investment' },
    { name: 'Miami Beach',   lat: 25.7907, lng: -80.1300, type: 'Luxury & International' },
    { name: 'Homestead',     lat: 25.4687, lng: -80.4776, type: 'USDA & FHA' },
    { name: 'Pinecrest',     lat: 25.6650, lng: -80.3046, type: 'High-End Homes' },
    { name: 'Westchester',   lat: 25.7465, lng: -80.3310, type: 'FHA & Families' },
    { name: 'South Miami',   lat: 25.7050, lng: -80.2916, type: 'Mixed Residential' }
  ];

  var mapInstance, markers = [];

  function initMap() {
    if (typeof L === 'undefined' || !document.getElementById('neighborhoods-map')) return;
    if (mapInstance) return;

    mapInstance = L.map('neighborhoods-map', { scrollWheelZoom: false }).setView([25.7617, -80.2918], 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18
    }).addTo(mapInstance);

    var icon = L.divIcon({
      className: '',
      html: '<div style="width:14px;height:14px;background:#D72A31;border:2px solid #fff;border-radius:50%;box-shadow:0 2px 6px rgba(0,0,0,.4);"></div>',
      iconSize: [14, 14],
      iconAnchor: [7, 7],
      popupAnchor: [0, -10]
    });

    neighborhoods.forEach(function(n, i) {
      var m = L.marker([n.lat, n.lng], { icon: icon })
        .addTo(mapInstance)
        .bindPopup('<strong>' + n.name + '</strong><br><span style="font-size:.8rem;color:#888;">' + n.type + '</span>');
      markers.push(m);
    });
  }

  window.focusNeighborhood = function(idx) {
    if (!mapInstance) return;
    var n = neighborhoods[idx];
    mapInstance.setView([n.lat, n.lng], 14, { animate: true });
    markers[idx].openPopup();
    document.querySelectorAll('.neighborhood-chip').forEach(function(c, i) {
      c.classList.toggle('active', i === idx);
    });
  };

  if (document.readyState === 'loading') {
    window.addEventListener('load', initMap);
  } else {
    initMap();
  }
})();
</script>

